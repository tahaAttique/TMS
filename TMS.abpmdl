      "folder": "src"
    },
    "TMS.Application.Contracts": {
      "path": "src/TMS.Application.Contracts/TMS.Application.Contracts.abppkg",
      "folder": "src"
    },
    "TMS.HttpApi": {
      "path": "src/TMS.HttpApi/TMS.HttpApi.abppkg",
      "folder": "src"
    },
    "TMS.HttpApi.Client": {
      "path": "src/TMS.HttpApi.Client/TMS.HttpApi.Client.abppkg",
      "folder": "src"
    },
    "TMS.EntityFrameworkCore.Tests": {
      "path": "test/TMS.EntityFrameworkCore.Tests/TMS.EntityFrameworkCore.Tests.abppkg",
      "folder": "test"
    },
    "TMS.EntityFrameworkCore": {
      "path": "src/TMS.EntityFrameworkCore/TMS.EntityFrameworkCore.abppkg",
      "folder": "src"
    },
    "TMS.TestBase": {
      "path": "test/TMS.TestBase/TMS.TestBase.abppkg",
      "folder": "test"
    },
    "TMS.Domain.Tests": {
      "path": "test/TMS.Domain.Tests/TMS.Domain.Tests.abppkg",

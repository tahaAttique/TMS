      "folder": "test"
    },
    "TMS.DbMigrator": {
      "path": "src/TMS.DbMigrator/TMS.DbMigrator.abppkg",
      "folder": "src"
    },
    "TMS.HttpApi.Host": {
      "path": "src/TMS.HttpApi.Host/TMS.HttpApi.Host.abppkg",
      "folder": "src"
    },
    "TMS.Domain": {
